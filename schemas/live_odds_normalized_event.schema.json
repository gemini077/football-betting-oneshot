{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://football-betting-oneshot.local/schemas/live_odds_normalized_event.schema.json",
  "title": "Football Betting OneShot normalized live market event",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "captured_at",
    "received_at",
    "match_id",
    "analysis_input_only",
    "lock_state_changed",
    "bankroll_state_changed",
    "in_play_betting_enabled"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "record_type": { "enum": ["odds_quote", "match_clock", "match_metadata", "market_definition"] },
    "captured_at": { "type": "string", "format": "date-time" },
    "received_at": { "type": "string", "format": "date-time" },
    "page_url": { "type": "string" },
    "match_id": { "type": "string", "minLength": 1 },
    "market_code": { "type": "string" },
    "market_name": {},
    "market_name_secondary": {},
    "child_market_code": { "type": "string" },
    "market_id": { "type": "string" },
    "market_type": {},
    "market_status": {},
    "handicap_line": {},
    "selection_code": {},
    "selection_name": {},
    "selection_id": { "type": "string" },
    "selection_status": {},
    "raw_odds": {},
    "base_raw_odds": {},
    "inferred_decimal_odds": { "type": ["number", "null"], "exclusiveMinimum": 0 },
    "display_price": {},
    "odds_encoding": { "const": "scaled_integer_1e5_inferred" },
    "odds_scale_verified": { "type": "boolean" },
    "odds_scale_verification_basis": {
      "type": ["string", "null"],
      "enum": ["direct_display_price_crosscheck", "same_match_ov_field_peer_crosscheck", null]
    },
    "source_timestamp_ms": {},
    "match_status": {},
    "match_period": {},
    "server_time_ms": {},
    "home_name": {},
    "away_name": {},
    "tournament_name": {},
    "kickoff_timestamp": {},
    "home_score": {},
    "away_score": {},
    "score_data": {},
    "sport_id": {},
    "analysis_input_only": { "const": true },
    "lock_state_changed": { "const": false },
    "bankroll_state_changed": { "const": false },
    "in_play_betting_enabled": { "const": false }
  },
  "additionalProperties": true
}
